# ==============================================================================
# Meeting-Prepper Environment Configuration
# Copy this file to `.env` and fill in the values you need.
#
#   [Required]   – the app will fail to start without this
#   [Optional]   – feature stays disabled if unset
# ==============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
# [Optional] Port the HTTP server listens on (default: 3000)
PORT=3000
# [Optional] Runtime mode: development | production | test
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# [Optional] SQLite file path (default: ./data/meeting-prepper.db)
# Use ":memory:" for ephemeral test runs.
DATABASE_PATH=./data/meeting-prepper.db

# ── Obsidian Adapter ──────────────────────────────────────────────────────────
# [Optional] Absolute path to your Obsidian vault. Adapter is disabled if unset.
OBSIDIAN_VAULT_PATH=

# ── Calendar Adapter ──────────────────────────────────────────────────────────
# [Optional] iCal/ICS feed URL. Adapter is disabled if unset.
CALENDAR_ICS_URL=

# ── Krisp MCP ─────────────────────────────────────────────────────────────────
# [Optional] MCP server URL for Krisp transcripts.
KRISP_MCP_SERVER_URL=

# ── Granola MCP ───────────────────────────────────────────────────────────────
# [Optional] MCP server URL for Granola meeting notes.
GRANOLA_MCP_SERVER_URL=

# ── Linear (action-item sync) ─────────────────────────────────────────────────
# [Required for Linear sync] Personal API key from Linear.
LINEAR_API_KEY=
# [Required for Linear sync] Default team ID for newly created issues.
LINEAR_TEAM_ID=
# [Required for Linear webhooks] Shared secret used to verify HMAC signatures
# on incoming /webhooks/linear requests. Without it, webhooks are rejected.
LINEAR_WEBHOOK_SECRET=

# ── Notifications ─────────────────────────────────────────────────────────────
# [Optional] Outbound webhook for system notifications (Slack/Discord/etc).
NOTIFICATION_WEBHOOK_URL=

# ── MCP Server (npm run mcp) ──────────────────────────────────────────────────
# [Required to start MCP server] Bearer token clients must send in
# Authorization header. Without it, `npm run mcp` exits immediately —
# there is no public default.
MCP_SERVER_TOKEN=
# [Optional] Port the MCP server listens on (default: 3001)
MCP_PORT=3001

# ── Logging ───────────────────────────────────────────────────────────────────
# [Optional] Log verbosity: debug | info | warn | error (default: info)
LOG_LEVEL=info
